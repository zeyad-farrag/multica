# team-app standalone server — required boot variables (AR8, Story 1.1 AC5).
# Missing or empty values fail-fast at boot. Copy to .env and fill in.

# Auto-seeded organisation (used by Story 1.6's 002 migration).
DEFAULT_ORG_SLUG=acme
DEFAULT_ORG_NAME=Acme Inc

# Org self-service is disabled in v1; POST /api/v1/orgs returns 403 when false.
# Accepts case-insensitive true/false (1/0/t/f); empty or unparseable → fail.
ORG_CREATION_ENABLED=false

# Constant-time-compared secret shared with the Multica fork's gate + inbox.
# Generate with: openssl rand -hex 32
TEAM_APP_SHARED_SECRET=replace-me-openssl-rand-hex-32

# Public base URL of this app (Multica fork calls /gates/* via this).
TEAM_APP_URL=https://team.multica.uittai.com

# Multica REST and WS endpoints.
MULTICA_BASE_URL=https://multica.uittai.com
MULTICA_WS_URL=wss://multica.uittai.com/ws

# PAT issued to the team-app-system Multica user. Story 1.9 will additionally
# assert that GET /api/me with this PAT returns the user below.
TEAM_APP_SYSTEM_USER_PAT=mpat_replace_me
TEAM_APP_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# Postgres DSN for the team_app database. The compose file points the api
# service at the db service via this URL; pgxpool.New consumes it directly.
DATABASE_URL=postgresql://postgres:postgres@db:5432/team_app?sslmode=disable
